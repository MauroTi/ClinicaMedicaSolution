@model ClinicaMedica.Web.ViewModels.Pacientes.PacienteIndexViewModel

@{
    ViewData["Title"] = "Pacientes";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Pacientes</h2>
        <a asp-action="Create" class="btn btn-primary">Novo Paciente</a>
    </div>

    @if (TempData["Sucesso"] != null)
    {
        <div class="alert alert-success">@TempData["Sucesso"]</div>
    }

    <table class="table table-striped table-bordered">
        <thead>
            <tr>
                <th>Nome</th>
                <th>CPF</th>
                <th>Telefone</th>
                <th>Email</th>
                <th>Data Nascimento</th>
                <th>Ativo</th>
                <th>Data Cadastro</th>
                <th style="width: 220px;">Ações</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Pacientes.Any())
            {
                foreach (var item in Model.Pacientes)
                {
                    <tr>
                        <td>@item.Nome</td>
                        <td>@item.Cpf</td>
                        <td>@item.Telefone</td>
                        <td>@item.Email</td>
                        <td>@item.DataNascimento.ToString("dd/MM/yyyy")</td>
                        <td>@(item.Ativo ? "Sim" : "Não")</td>
                        <td>@item.DataCadastro.ToString("dd/MM/yyyy HH:mm")</td>
                        <td>
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Detalhes</a>
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Editar</a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Excluir</a>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="8" class="text-center">Nenhum paciente encontrado.</td>
                </tr>
            }
        </tbody>
    </table>

    <partial name="_Pagination" model="Model.Pagination" />
</div>
