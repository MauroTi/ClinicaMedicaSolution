@model ClinicaMedica.Web.Models.Paciente

@{
    ViewData["Title"] = "Excluir Paciente";
}

<div class="container mt-4">
    <h2>Excluir Paciente</h2>

    <div class="alert alert-danger mt-3">
        <strong>Atenção!</strong> Tem certeza que deseja excluir este paciente?
    </div>

    <div class="card mt-3">
        <div class="card-body">
            <p><strong>Nome:</strong> @Model.Nome</p>
            <p><strong>CPF:</strong> @Model.Cpf</p>
            <p><strong>Telefone:</strong> @Model.Telefone</p>
            <p><strong>Email:</strong> @Model.Email</p>
            <p><strong>Data de Nascimento:</strong> @Model.DataNascimento.ToString("dd/MM/yyyy")</p>
            <p><strong>Ativo:</strong> @(Model.Ativo ? "Sim" : "Não")</p>
            <p><strong>Data de Cadastro:</strong> @Model.DataCadastro.ToString("dd/MM/yyyy HH:mm")</p>
        </div>
    </div>

    <form asp-action="Delete" method="post" class="mt-3">
        <input type="hidden" asp-for="Id" />
        <button type="submit" class="btn btn-danger">Excluir</button>
        <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
    </form>
</div>