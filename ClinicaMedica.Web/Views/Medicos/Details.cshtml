@model ClinicaMedica.Web.Models.Medico

@{
    ViewData["Title"] = "Detalhes do Médico";
}

<div class="container mt-4">
    <h2>Detalhes do Médico</h2>

    <div class="card mt-3">
        <div class="card-body">
            <p><strong>Nome:</strong> @Model.Nome</p>
            <p><strong>Especialidade:</strong> @Model.Especialidade</p>
            <p><strong>CRM:</strong> @Model.Crm</p>
            <p><strong>Telefone:</strong> @Model.Telefone</p>
            <p><strong>Email:</strong> @Model.Email</p>
            <p><strong>Ativo:</strong> @(Model.Ativo ? "Sim" : "Não")</p>
            <p><strong>Data de Cadastro:</strong> @Model.DataCadastro.ToString("dd/MM/yyyy HH:mm")</p>
        </div>
    </div>

    <div class="mt-3">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Editar</a>
        <a asp-action="Index" class="btn btn-secondary">Voltar</a>
    </div>
</div>