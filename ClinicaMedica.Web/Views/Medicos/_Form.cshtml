@model ClinicaMedica.Web.ViewModels.Medicos.MedicoFormViewModel

<form asp-action="@ViewData["Action"]" method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

    <input asp-for="Id" type="hidden" />

    <div class="mb-3">
        <label asp-for="Nome" class="form-label"></label>
        <input asp-for="Nome" class="form-control" />
        <span asp-validation-for="Nome" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Especialidade" class="form-label"></label>
        <input asp-for="Especialidade" class="form-control" />
        <span asp-validation-for="Especialidade" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Crm" class="form-label"></label>
        <input asp-for="Crm" class="form-control" />
        <span asp-validation-for="Crm" class="text-danger"></span>
    </div>

    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary">Salvar</button>
        <a asp-action="Index" class="btn btn-secondary">Voltar</a>
    </div>
</form>