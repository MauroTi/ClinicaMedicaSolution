@model ClinicaMedica.Web.ViewModels.Shared.PaginationViewModel

@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();

    var startPage = Math.Max(1, Model.CurrentPage - 2);
    var endPage = Math.Min(Model.TotalPages, Model.CurrentPage + 2);
}

@if (Model.TotalPages > 1)
{
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-2 mt-3">

        <small class="text-muted">
            Mostrando @Model.StartItem - @Model.EndItem de @Model.TotalItems registros
        </small>

        <div class="btn-group" role="group">

            <!-- Anterior -->
            @if (Model.HasPreviousPage)
            {
                <a class="btn btn-outline-primary btn-sm"
                   asp-controller="@currentController"
                   asp-action="Index"
                   asp-route-page="@(Model.CurrentPage - 1)">
                    «
                </a>
            }
            else
            {
                <span class="btn btn-outline-secondary btn-sm disabled">«</span>
            }

            <!-- Primeira -->
            @if (startPage > 1)
            {
                <a class="btn btn-outline-primary btn-sm"
                   asp-controller="@currentController"
                   asp-action="Index"
                   asp-route-page="1">1</a>

                @if (startPage > 2)
                {
                    <span class="btn btn-sm disabled">...</span>
                }
            }

            <!-- Páginas -->
            @for (var pageNumber = startPage; pageNumber <= endPage; pageNumber++)
            {
                if (pageNumber == Model.CurrentPage)
                {
                    <span class="btn btn-primary btn-sm active">@pageNumber</span>
                }
                else
                {
                    <a class="btn btn-outline-primary btn-sm"
                       asp-controller="@currentController"
                       asp-action="Index"
                       asp-route-page="@pageNumber">
                        @pageNumber
                    </a>
                }
            }

            <!-- Última -->
            @if (endPage < Model.TotalPages)
            {
                @if (endPage < Model.TotalPages - 1)
                {
                    <span class="btn btn-sm disabled">...</span>
                }

                <a class="btn btn-outline-primary btn-sm"
                   asp-controller="@currentController"
                   asp-action="Index"
                   asp-route-page="@Model.TotalPages">
                    @Model.TotalPages
                </a>
            }

            <!-- Próxima -->
            @if (Model.HasNextPage)
            {
                <a class="btn btn-outline-primary btn-sm"
                   asp-controller="@currentController"
                   asp-action="Index"
                   asp-route-page="@(Model.CurrentPage + 1)">
                    »
                </a>
            }
            else
            {
                <span class="btn btn-outline-secondary btn-sm disabled">»</span>
            }

        </div>
    </div>
}