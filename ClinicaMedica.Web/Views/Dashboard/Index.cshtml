@model ClinicaMedica.Web.ViewModels.Dashboard.DashboardViewModel

@{
    ViewData["Title"] = "Dashboard";
}

<div class="container mt-4">
    <h2 class="mb-4">Dashboard da Clínica</h2>

    <div class="row g-3">
        <div class="col-md-3">
            <div class="card border-primary shadow-sm">
                <div class="card-body">
                    <h5 class="card-title">Pacientes</h5>
                    <p class="display-6">@Model.TotalPacientes</p>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-success shadow-sm">
                <div class="card-body">
                    <h5 class="card-title">Médicos</h5>
                    <p class="display-6">@Model.TotalMedicos</p>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-warning shadow-sm">
                <div class="card-body">
                    <h5 class="card-title">Consultas</h5>
                    <p class="display-6">@Model.TotalConsultas</p>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-danger shadow-sm">
                <div class="card-body">
                    <h5 class="card-title">Agendadas</h5>
                    <p class="display-6">@Model.ConsultasAgendadas</p>
                </div>
            </div>
        </div>

        <div class="col-md-3 mt-3">
            <div class="card border-info shadow-sm">
                <div class="card-body">
                    <h5 class="card-title">Realizadas</h5>
                    <p class="display-6">@Model.ConsultasRealizadas</p>
                </div>
            </div>
        </div>

        <div class="col-md-3 mt-3">
            <div class="card border-secondary shadow-sm">
                <div class="card-body">
                    <h5 class="card-title">Canceladas</h5>
                    <p class="display-6">@Model.ConsultasCanceladas</p>
                </div>
            </div>
        </div>

        <div class="col-md-3 mt-3">
            <div class="card border-dark shadow-sm">
                <div class="card-body">
                    <h5 class="card-title">Receita Total</h5>
                    <p class="display-6">@Model.ReceitaTotal.ToString("C")</p>
                </div>
            </div>
        </div>
    </div>
</div>