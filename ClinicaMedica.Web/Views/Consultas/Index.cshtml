@model ClinicaMedica.Web.ViewModels.Consultas.ConsultaIndexViewModel

@{
    ViewData["Title"] = "Consultas";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Consultas</h2>
        <a asp-action="Create" class="btn btn-primary">Nova Consulta</a>
    </div>

    @if (TempData["Sucesso"] != null)
    {
        <div class="alert alert-success">@TempData["Sucesso"]</div>
    }

    <table class="table table-striped table-bordered">
        <thead>
            <tr>
                <th>Médico</th>
                <th>Paciente</th>
                <th>Data/Hora</th>
                <th>Valor</th>
                <th>Status</th>
                <th>Observações</th>
                <th>Data Cadastro</th>
                <th style="width: 220px;">Ações</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Consultas)
            {
                <tr>
                    <td>@item.MedicoNome</td>
                    <td>@item.PacienteNome</td>
                    <td>@item.DataHoraConsulta.ToString("dd/MM/yyyy HH:mm")</td>
                    <td>@item.Valor.ToString("C")</td>
                    <td>@item.Status</td>
                    <td>@item.Observacoes</td>
                    <td>@item.DataCadastro.ToString("dd/MM/yyyy HH:mm")</td>
                    <td>
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Detalhes</a>
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Editar</a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Excluir</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>