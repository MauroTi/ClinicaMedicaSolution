@model ClinicaMedica.Consumidor.ViewModels.HomeViewModel
@using Microsoft.AspNetCore.Http

@{
    ViewData["Title"] = "Dashboard";
    var db = Context.Session.GetString("database") ?? "mysql";
}

<div class="container mt-4">
    <div class="text-center mb-4">
        <h1 class="display-5 fw-bold">Dashboard da Clínica Médica</h1>
        <p class="text-muted">Visão geral do sistema</p>
    </div>

    <div class="row g-4">
        <div class="col-md-4">
            <div class="card shadow-sm border-0 rounded-3 h-100">
                <div class="card-body text-center">
                    <h5 class="card-title text-primary">Total de Médicos</h5>
                    <h2 class="fw-bold">@Model.TotalMedicos</h2>
                    <a asp-controller="Medicos" asp-action="Index" asp-route-database="@db" class="btn btn-outline-primary w-100">Ver Médicos </a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm border-0 rounded-3 h-100">
                <div class="card-body text-center">
                    <h5 class="card-title text-success">Total de Pacientes</h5>
                    <h2 class="fw-bold">@Model.TotalPacientes</h2>
                    <a asp-controller="Pacientes" asp-action="Index" asp-route-database="@db" class="btn btn-outline-primary w-100">Ver Pacientes </a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm border-0 rounded-3 h-100">
                <div class="card-body text-center">
                    <h5 class="card-title text-warning">Total de Consultas</h5>
                    <h2 class="fw-bold">@Model.TotalConsultas</h2>
                    <a asp-controller="Consultas" asp-action="Index" asp-route-database="@db" class="btn btn-outline-primary w-100">Ver Consultas </a>
                </div>
            </div>
        </div>
    </div>
</div>
