@model IEnumerable<ClinicaMedica.Consumidor.ViewModels.PacienteViewModel>

<h2>Pacientes</h2>

<p>
    <a class="btn btn-primary" asp-action="Create">Novo Paciente</a>
</p>

<table class="table table-striped table-bordered">
    <thead>
        <tr>
            <th>Nome</th>
            <th>CPF</th>
            <th>Telefone</th>
            <th>Email</th>
            <th>Data Nascimento</th>
            <th>Ativo</th>
            <th>Ações</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var p in Model)
        {
            <tr>
                <td>@p.Nome</td>
                <td>@p.Cpf</td>
                <td>@p.Telefone</td>
                <td>@p.Email</td>
                <td>@p.DataNascimento?.ToString("dd/MM/yyyy")</td>
                <td>@(p.Ativo ? "Sim" : "Não")</td>
                <td>
                    <a class="btn btn-info btn-sm" asp-action="Details" asp-route-id="@p.Id">Ver</a>
                    <a class="btn btn-warning btn-sm" asp-action="Edit" asp-route-id="@p.Id">Editar</a>
                    <a class="btn btn-danger btn-sm" asp-action="Delete" asp-route-id="@p.Id">Excluir</a>
                </td>
            </tr>
        }
    </tbody>
</table>