@model IEnumerable<ClinicaMedica.Consumidor.ViewModels.PacienteViewModel>

@{
    ViewData["Title"] = "Pacientes";
}

<h2>Pacientes</h2>

@if (TempData["Sucesso"] != null)
{
    <div class="alert alert-success">
        @TempData["Sucesso"]
    </div>
}

@if (TempData["Erro"] != null)
{
    <div class="alert alert-danger">
        @TempData["Erro"]
    </div>
}

@if (ViewData["ErroApi"] != null)
{
    <div class="alert alert-danger">
        <strong>Erro ao consumir a API:</strong><br />
        @ViewData["ErroApi"]
    </div>
}

<p>
    <a asp-action="Create" class="btn btn-primary">Novo Paciente</a>
</p>

<table class="table table-striped table-bordered">
    <thead>
        <tr>
            <th>Id</th>
            <th>Nome</th>
            <th>CPF</th>
            <th>Telefone</th>
            <th>Email</th>
            <th>Data Nascimento</th>
            <th>Ativo</th>
            <th>Data Cadastro</th>
            <th style="width: 220px;">Ações</th>
        </tr>
    </thead>
    <tbody>
        @if (Model != null && Model.Any())
        {
            foreach (var paciente in Model)
            {
                <tr>
                    <td>@paciente.Id</td>
                    <td>@paciente.Nome</td>
                    <td>@paciente.Cpf</td>
                    <td>@paciente.Telefone</td>
                    <td>@paciente.Email</td>
                    <td>@paciente.DataNascimento.ToString("dd/MM/yyyy")</td>
                    <td>@(paciente.Ativo ? "Sim" : "Não")</td>
                    <td>@paciente.DataCadastro.ToString("dd/MM/yyyy HH:mm")</td>
                    <td>
                        <a asp-action="Details" asp-route-id="@paciente.Id" class="btn btn-info btn-sm">Detalhes</a>
                        <a asp-action="Edit" asp-route-id="@paciente.Id" class="btn btn-warning btn-sm">Editar</a>
                        <a asp-action="Delete" asp-route-id="@paciente.Id" class="btn btn-danger btn-sm">Excluir</a>
                    </td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="9" class="text-center">Nenhum paciente encontrado.</td>
            </tr>
        }
    </tbody>
</table>