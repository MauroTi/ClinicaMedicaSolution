@model ClinicaMedica.Consumidor.ViewModels.PacienteViewModel

@{
    ViewData["Title"] = "Detalhes do Paciente";
}

<h2>Detalhes do Paciente</h2>

<dl class="row">
    <dt class="col-sm-3">Nome</dt>
    <dd class="col-sm-9">@Model.Nome</dd>

    <dt class="col-sm-3">CPF</dt>
    <dd class="col-sm-9">@Model.Cpf</dd>

    <dt class="col-sm-3">Telefone</dt>
    <dd class="col-sm-9">@Model.Telefone</dd>

    <dt class="col-sm-3">Email</dt>
    <dd class="col-sm-9">@Model.Email</dd>

    <dt class="col-sm-3">Data de Nascimento</dt>
    <dd class="col-sm-9">@Model.DataNascimento.ToString("dd/MM/yyyy")</dd>

    <dt class="col-sm-3">Ativo</dt>
    <dd class="col-sm-9">@(Model.Ativo ? "Sim" : "Não")</dd>

    <dt class="col-sm-3">Data de Cadastro</dt>
    <dd class="col-sm-9">@Model.DataCadastro.ToString("dd/MM/yyyy HH:mm")</dd>
</dl>

<a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Editar</a>
<a asp-action="Index" class="btn btn-secondary">Voltar</a>