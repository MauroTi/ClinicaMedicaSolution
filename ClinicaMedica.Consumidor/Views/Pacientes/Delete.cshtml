@model ClinicaMedica.Consumidor.ViewModels.PacienteViewModel

@{
    ViewData["Title"] = "Excluir Paciente";
}

<h2>Excluir Paciente</h2>

<div class="alert alert-warning">
    Tem certeza que deseja excluir o paciente <strong>@Model.Nome</strong>?
</div>

<dl class="row">
    <dt class="col-sm-3">CPF</dt>
    <dd class="col-sm-9">@Model.Cpf</dd>

    <dt class="col-sm-3">Email</dt>
    <dd class="col-sm-9">@Model.Email</dd>

    <dt class="col-sm-3">Data de Nascimento</dt>
    <dd class="col-sm-9">@Model.DataNascimento.ToString("dd/MM/yyyy")</dd>
</dl>

<form asp-action="Delete" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Excluir</button>
    <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
</form>