@model IEnumerable<ClinicaMedica.Consumidor.ViewModels.ConsultaViewModel>

@{
    ViewData["Title"] = "Consultas";
}

<h2>Consultas</h2>

@if (TempData["Sucesso"] != null)
{
    <div class="alert alert-success">@TempData["Sucesso"]</div>
}

@if (TempData["Erro"] != null)
{
    <div class="alert alert-danger">@TempData["Erro"]</div>
}

@if (ViewData["ErroApi"] != null)
{
    <div class="alert alert-danger">
        <strong>Erro ao consumir a API:</strong><br />
        @ViewData["ErroApi"]
    </div>
}

<p>
    <a asp-action="Create" class="btn btn-primary">Nova Consulta</a>
</p>

<table class="table table-striped table-bordered">
    <thead>
        <tr>
            <th>ID</th>
            <th>Médico</th>
            <th>Paciente</th>
            <th>Data/Hora</th>
            <th>Valor</th>
            <th>Status</th>
            <th>Observações</th>
            <th>Data Cadastro</th>
            <th>Ações</th>
        </tr>
    </thead>
    <tbody>
        @if (Model != null && Model.Any())
        {
            foreach (var consulta in Model)
            {
                <tr>
                    <td>@consulta.Id</td>
                    <td>@consulta.NomeMedico</td>
                    <td>@consulta.NomePaciente</td>
                    <td>@consulta.DataHoraConsulta.ToString("dd/MM/yyyy HH:mm")</td>
                    <td>@consulta.Valor.ToString("C")</td>
                    <td>@consulta.Status</td>
                    <td>@consulta.Observacoes</td>
                    <td>@consulta.DataCadastro.ToString("dd/MM/yyyy HH:mm")</td>
                    <td>
                        <a asp-action="Details" asp-route-id="@consulta.Id" class="btn btn-info btn-sm">Detalhes</a>
                        <a asp-action="Edit" asp-route-id="@consulta.Id" class="btn btn-warning btn-sm">Editar</a>
                        <a asp-action="Delete" asp-route-id="@consulta.Id" class="btn btn-danger btn-sm">Excluir</a>
                    </td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="9" class="text-center">Nenhuma consulta encontrada.</td>
            </tr>
        }
    </tbody>
</table>