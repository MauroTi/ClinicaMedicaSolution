@model ClinicaMedica.Consumidor.ViewModels.ConsultaIndexViewModel

@{
    ViewData["Title"] = "Consultas";
    var db = Model.Pagination.Database;
}

<h2>Consultas</h2>

@if (TempData["Sucesso"] != null)
{
    <div class="alert alert-success">@TempData["Sucesso"]</div>
}

@if (TempData["Erro"] != null)
{
    <div class="alert alert-danger">@TempData["Erro"]</div>
}

@if (ViewData["ErroApi"] != null)
{
    <div class="alert alert-danger">
        <strong>Erro ao consumir a API:</strong><br />
        @ViewData["ErroApi"]
    </div>
}

<p>
    <a asp-action="Create" asp-route-database="@db" class="btn btn-primary mb-3">Nova Consulta</a>
</p>

<div class="table-responsive">
    <table class="table table-striped table-bordered align-middle w-100">
        <thead class="table-light">
            <tr>
                <th style="display:none;">ID</th>
                <th>Médico</th>
                <th>Paciente</th>
                <th>Data/Hora</th>
                <th>Valor</th>
                <th>Status</th>
                <th>Observações</th>
                <th>Data Cadastro</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Consultas.Any())
            {
                foreach (var consulta in Model.Consultas)
                {
                    <tr>
                        <td style="display:none;">@consulta.Id</td>
                        <td>@consulta.NomeMedico</td>
                        <td>@consulta.NomePaciente</td>
                        <td>@consulta.DataHoraConsulta.ToString("dd/MM/yyyy HH:mm")</td>
                        <td>@consulta.Valor.ToString("C")</td>
                        <td>@consulta.Status</td>
                        <td style="max-width: 160px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;" title="@consulta.Observacoes">
                            @consulta.Observacoes
                        </td>
                        <td>@consulta.DataCadastro.ToString("dd/MM/yyyy HH:mm")</td>
                        <td class="text-center">
                            <div class="d-flex gap-1 justify-content-center" style="flex-wrap:nowrap;">
                                <a asp-action="Details" asp-route-id="@consulta.Id" asp-route-database="@db" class="btn btn-primary btn-sm" style="white-space:nowrap; min-width:60px; flex-shrink:1;">Detalhes</a>
                                <a asp-action="Edit" asp-route-id="@consulta.Id" asp-route-database="@db" class="btn btn-warning btn-sm" style="white-space:nowrap; min-width:60px; flex-shrink:1;">Editar</a>
                                <a asp-action="Delete" asp-route-id="@consulta.Id" asp-route-database="@db" class="btn btn-danger btn-sm" style="white-space:nowrap; min-width:60px; flex-shrink:1;">Excluir</a>
                            </div>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="9" class="text-center">Nenhuma consulta encontrada.</td>
                </tr>
            }
        </tbody>
    </table>
</div>

<partial name="_Pagination" model="Model.Pagination" />
