@model ClinicaMedica.Consumidor.ViewModels.ConsultaViewModel

<h2>Editar Consulta</h2>

<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="Id" />
    
    
    <div class="form-group">
        <label asp-for="DataHoraConsulta"></label>
        <input asp-for="DataHoraConsulta" class="form-control" type="datetime-local" />
    </div>
    <div class="form-group">
        <label asp-for="Valor"></label>
        <input asp-for="Valor" class="form-control" type="number" step="0.01" />
    </div>
    <div class="form-group">
        <label asp-for="Status"></label>
        <input asp-for="Status" class="form-control" />
    </div>
    <div class="form-group">
        <label asp-for="Observacoes"></label>
        <textarea asp-for="Observacoes" class="form-control"></textarea>
    </div>
    <button type="submit" class="btn btn-success mt-2">Salvar</button>
    <a asp-action="Index" class="btn btn-secondary mt-2">Cancelar</a>
</form>