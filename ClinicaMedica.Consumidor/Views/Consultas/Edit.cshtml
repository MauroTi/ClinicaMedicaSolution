@model ClinicaMedica.Consumidor.ViewModels.ConsultaViewModel
@using Microsoft.AspNetCore.Mvc.Rendering

@{
    ViewData["Title"] = "Editar Consulta";
}

<h2>Editar Consulta</h2>

<div class="row">
    <div class="col-md-8">
        <form asp-action="Edit" asp-route-id="@Model.Id" method="post">
            @Html.AntiForgeryToken()

            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="DataCadastro" />

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="MedicoId" class="form-label">Médico</label>
                <select asp-for="MedicoId"
                        class="form-select"
                        asp-items="@(new SelectList(Model.Medicos, "Id", "Nome"))">
                    <option value="">Selecione um médico</option>
                </select>
                <span asp-validation-for="MedicoId" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="PacienteId" class="form-label">Paciente</label>
                <select asp-for="PacienteId"
                        class="form-select"
                        asp-items="@(new SelectList(Model.Pacientes, "Id", "Nome"))">
                    <option value="">Selecione um paciente</option>
                </select>
                <span asp-validation-for="PacienteId" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="DataHoraConsulta" class="form-label">Data e Hora da Consulta</label>
                <input asp-for="DataHoraConsulta"
                       type="datetime-local"
                       class="form-control"
                       value="@Model.DataHoraConsulta.ToString("yyyy-MM-ddTHH:mm")" />
                <span asp-validation-for="DataHoraConsulta" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Valor" class="form-label">Valor</label>
                <input asp-for="Valor" type="number" step="0.01" min="0" class="form-control" />
                <span asp-validation-for="Valor" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Status" class="form-label">Status</label>
                <select asp-for="Status" class="form-select">
                    <option value="">Selecione o status</option>
                    <option value="Agendada">Agendada</option>
                    <option value="Realizada">Realizada</option>
                    <option value="Cancelada">Cancelada</option>
                </select>
                <span asp-validation-for="Status" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Observacoes" class="form-label">Observações</label>
                <textarea asp-for="Observacoes" class="form-control" rows="4"></textarea>
                <span asp-validation-for="Observacoes" class="text-danger"></span>
            </div>

            <div class="mt-4">
                <button type="submit" class="btn btn-primary">Salvar Alterações</button>
                <a asp-action="Index" class="btn btn-secondary">Voltar</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}