@model ClinicaMedica.Consumidor.ViewModels.ConsultaViewModel

@{
    ViewData["Title"] = "Nova Consulta";
}

<h2>Nova Consulta</h2>

<form asp-action="Create" method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="form-group mb-3">
        <label asp-for="MedicoId" class="form-label"></label>
        <select asp-for="MedicoId" class="form-control">
            <option value="">Selecione o médico</option>
            @foreach (var medico in Model.Medicos)
            {
                <option value="@medico.Id">@medico.Nome</option>
            }
        </select>
        <span asp-validation-for="MedicoId" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label asp-for="PacienteId" class="form-label"></label>
        <select asp-for="PacienteId" class="form-control">
            <option value="">Selecione o paciente</option>
            @foreach (var paciente in Model.Pacientes)
            {
                <option value="@paciente.Id">@paciente.Nome</option>
            }
        </select>
        <span asp-validation-for="PacienteId" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label asp-for="DataHoraConsulta" class="form-label"></label>
        <input asp-for="DataHoraConsulta" class="form-control" type="datetime-local"
               value="@(Model.DataHoraConsulta == default ? "" : Model.DataHoraConsulta.ToString("yyyy-MM-ddTHH:mm"))" />
        <span asp-validation-for="DataHoraConsulta" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label asp-for="Valor" class="form-label"></label>
        <input asp-for="Valor" class="form-control" type="number" step="0.01" />
        <span asp-validation-for="Valor" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Status" class="form-label">Status</label>
        <select asp-for="Status" class="form-select">
            <option value="">Selecione o status</option>
            <option value="Agendada">Agendada</option>
            <option value="Realizada">Realizada</option>
            <option value="Cancelada">Cancelada</option>
        </select>
        <span asp-validation-for="Status" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label asp-for="Observacoes" class="form-label"></label>
        <textarea asp-for="Observacoes" class="form-control" rows="3"></textarea>
        <span asp-validation-for="Observacoes" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-success">Salvar</button>
    <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}