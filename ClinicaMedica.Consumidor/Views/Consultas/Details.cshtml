@model ClinicaMedica.Consumidor.ViewModels.ConsultaViewModel

<h2>Detalhes da Consulta</h2>

<dl class="row">
    <dt class="col-sm-2">Médico</dt>
    <dd class="col-sm-10">@Model.NomeMedico</dd>

    <dt class="col-sm-2">Paciente</dt>
    <dd class="col-sm-10">@Model.NomePaciente</dd>

    <dt class="col-sm-2">Data/Hora</dt>
    <dd class="col-sm-10">@Model.DataHoraConsulta.ToString("dd/MM/yyyy HH:mm")</dd>

    <dt class="col-sm-2">Valor</dt>
    <dd class="col-sm-10">@(Model.Valor.ToString("C") )</dd>

    <dt class="col-sm-2">Status</dt>
    <dd class="col-sm-10">@Model.Status</dd>

    <dt class="col-sm-2">Observações</dt>
    <dd class="col-sm-10">@Model.Observacoes</dd>
</dl>

<a asp-action="Index" class="btn btn-secondary">Voltar</a>