@model ClinicaMedica.Consumidor.ViewModels.MedicoViewModel

<h2>Detalhes do Médico</h2>

<dl class="row">
    <dt class="col-sm-2">Nome</dt>
    <dd class="col-sm-10">@Model.Nome</dd>

    <dt class="col-sm-2">Especialidade</dt>
    <dd class="col-sm-10">@Model.Especialidade</dd>

    <dt class="col-sm-2">CRM</dt>
    <dd class="col-sm-10">@Model.Crm</dd>

    <dt class="col-sm-2">Telefone</dt>
    <dd class="col-sm-10">@Model.Telefone</dd>

    <dt class="col-sm-2">Email</dt>
    <dd class="col-sm-10">@Model.Email</dd>

    <dt class="col-sm-2">Ativo</dt>
    <dd class="col-sm-10">@(Model.Ativo ? "Sim" : "Não")</dd>
</dl>

<a asp-action="Index" class="btn btn-secondary">Voltar</a>