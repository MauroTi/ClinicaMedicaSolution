@model IEnumerable<ClinicaMedica.Consumidor.ViewModels.MedicoViewModel>

@{
    ViewData["Title"] = "Médicos";
}

<h2>Médicos</h2>

@if (TempData["Sucesso"] != null)
{
    <div class="alert alert-success">
        @TempData["Sucesso"]
    </div>
}

@if (TempData["Erro"] != null)
{
    <div class="alert alert-danger">
        @TempData["Erro"]
    </div>
}

@if (ViewData["ErroApi"] != null)
{
    <div class="alert alert-danger">
        <strong>Erro ao consumir a API:</strong><br />
        @ViewData["ErroApi"]
    </div>
}

<p>
    <a asp-action="Create" class="btn btn-primary mb-3">Novo Médico</a>
</p>

<div class="table-responsive">
    <table class="table table-striped table-bordered align-middle">
        <thead class="table-light">
            <tr>
                <th>Id</th>
                <th>Nome</th>
                <th>Especialidade</th>
                <th>CRM</th>
                <th>Telefone</th>
                <th>Email</th>
                <th>Ativo</th>
                <th>Data Cadastro</th>
                <th>Ações</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                foreach (var medico in Model)
                {
                    <tr>
                        <td>@medico.Id</td>
                        <td>@medico.Nome</td>
                        <td>@medico.Especialidade</td>
                        <td>@medico.Crm</td>
                        <td>@medico.Telefone</td>
                        <td style="max-width: 2200px;">
                            <div class="text-truncate" style="max-width: 200px;" title="@medico.Email">@medico.Email</div>
                        </td>
                        <td>@(medico.Ativo ? "Sim" : "Não")</td>
                        <td>@medico.DataCadastro.ToString("dd/MM/yyyy HH:mm")</td>
                        <td>
                            <div class="d-flex gap-1">
                                <a asp-action="Details" asp-route-id="@medico.Id" class="btn btn-info btn-sm flex-grow-1">Detalhes</a>
                                <a asp-action="Edit" asp-route-id="@medico.Id" class="btn btn-warning btn-sm flex-grow-1">Editar</a>
                                <a asp-action="Delete" asp-route-id="@medico.Id" class="btn btn-danger btn-sm flex-grow-1">Excluir</a>
                            </div>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="9" class="text-center">Nenhum médico encontrado.</td>
                </tr>
            }
        </tbody>
    </table>
</div>