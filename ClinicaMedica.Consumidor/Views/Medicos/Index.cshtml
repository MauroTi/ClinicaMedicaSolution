@model IEnumerable<ClinicaMedica.Consumidor.ViewModels.MedicoViewModel>

<h2>Médicos</h2>

<p>
    <a class="btn btn-primary" asp-action="Create">Novo Médico</a>
</p>

<table class="table table-striped table-bordered">
    <thead>
        <tr>
            <th>Nome</th>
            <th>Especialidade</th>
            <th>CRM</th>
            <th>Telefone</th>
            <th>Email</th>
            <th>Ativo</th>
            <th>Ações</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var m in Model)
        {
            <tr>
                <td>@m.Nome</td>
                <td>@m.Especialidade</td>
                <td>@m.Crm</td>
                <td>@m.Telefone</td>
                <td>@m.Email</td>
                <td>@(m.Ativo ? "Sim" : "Não")</td>
                <td>
                    <a class="btn btn-info btn-sm" asp-action="Details" asp-route-id="@m.Id">Ver</a>
                    <a class="btn btn-warning btn-sm" asp-action="Edit" asp-route-id="@m.Id">Editar</a>
                    <a class="btn btn-danger btn-sm" asp-action="Delete" asp-route-id="@m.Id">Excluir</a>
                </td>
            </tr>
        }
    </tbody>
</table>