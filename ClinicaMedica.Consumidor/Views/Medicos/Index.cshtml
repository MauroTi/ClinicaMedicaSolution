@model IEnumerable<ClinicaMedica.Consumidor.Models.Medico>

@{
    ViewData["Title"] = "Médicos";
}

<h2>Médicos</h2>

@if (ViewData["ErroApi"] != null)
{
    <div class="alert alert-danger">
        <strong>Erro ao consumir a API:</strong><br />
        @ViewData["ErroApi"]
    </div>
}

<table class="table table-striped table-bordered">
    <thead>
        <tr>
            <th>Id</th>
            <th>Nome</th>
            <th>Especialidade</th>
            <th>Crm</th>
            <th>Telefone</th>
            <th>Email</th>
            <th>Ativo</th>
            <th>DataCadastro</th>
        </tr>
    </thead>
    <tbody>
        @if (Model != null && Model.Any())
        {
            foreach (var medico in Model)
            {
                <tr>
                    <td>@medico.Id</td>
                    <td>@medico.Nome</td>
                    <td>@medico.Especialidade</td>
                    <td>@medico.Crm</td>
                    <td>@medico.Telefone</td>
                    <td>@medico.Email</td>
                    <td>@(medico.Ativo ? "Sim" : "Não")</td>
                    <td>@medico.DataCadastro.ToString("dd/MM/yyyy HH:mm")</td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="8" class="text-center">Nenhum médico encontrado.</td>
            </tr>
        }
    </tbody>
</table>