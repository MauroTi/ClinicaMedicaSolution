@using Microsoft.AspNetCore.Mvc.Rendering


<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Clínica Médica</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-primary shadow-sm">
            <div class="container-fluid">
                <a class="navbar-brand" href="@Url.Action("Index", "Home")">
                    <i class="bi bi-heart-pulse-fill text-light"></i> Clínica
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav ms-auto">
                        <li class="nav-item">
                            <a class="nav-link @(IsActive("Consultas", "Index"))" href="@Url.Action("Index", "Consultas")">Consultas</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(IsActive("Medicos", "Index"))" href="@Url.Action("Index", "Medicos")">Médicos</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(IsActive("Pacientes", "Index"))" href="@Url.Action("Index", "Pacientes")">Pacientes</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(IsActive("Consultas", "GraficoStatus"))" href="@Url.Action("GraficoStatus", "Consultas")">Gráficos</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main class="container mt-4">
        @RenderBody()
    </main>

    <footer class="bg-light text-center py-3 mt-5 border-top">
        &copy; @DateTime.Now.Year - Clínica Médica
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            document.querySelectorAll("table").forEach(table => {
                const headers = table.querySelectorAll("th");
                let idIndex = -1;

                // Encontra a coluna "ID"
                headers.forEach((th, i) => {
                    if(th.textContent.trim().toUpperCase() === "ID") {
                        idIndex = i;
                        th.style.display = "none"; // oculta o th
                    }
                });

                if(idIndex >= 0) {
                    // Oculta todas as td da coluna ID
                    table.querySelectorAll("tr").forEach(tr => {
                        const tds = tr.querySelectorAll("td");
                        if(tds[idIndex]) {
                            tds[idIndex].style.display = "none";
                        }
                    });
                }
            });
        });
    </script>

    @RenderSection("Scripts", required: false)

    @functions {
        private string IsActive(string controller, string action)
        {
            var routeData = ViewContext.RouteData;
            var currentAction = routeData.Values["action"]?.ToString();
            var currentController = routeData.Values["controller"]?.ToString();
            return (controller == currentController && action == currentAction) ? "active" : "";
        }
    }
</body>
</html>